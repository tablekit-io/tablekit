
# macOS junk
.DS_Store

# JetBrains IDE
.idea/
.env

# Generated widget builds embedded by core. These live in a //go:embed all:widgets
# directory, so a local .gitignore there would itself be embedded — hence these
# stay here. Only widgets/.gitkeep is committed so the embed compiles before the
# first build; the manifest and content-hashed HTML the vite build emits are ignored.
core/mcp/ui/widgets/*.html
core/mcp/ui/widgets/manifest.json

/data
# Real databases config (holds connection secrets); the default lookup is
# ./databases.{yaml,yml} in the working directory. Examples/dev configs are
# committed separately (databases.example.yml, core/databases.dev.yaml).
/databases.yaml
/databases.yml
/databases.example.yml
/docker-compose.example.yml
