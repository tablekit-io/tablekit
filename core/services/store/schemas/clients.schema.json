{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "clients.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "pairing_mode": { "enum": ["once", "indefinite", "disabled"] },
    "paired_client_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "paired_client_id": { "type": "string" },
    "clients": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/client" }
    }
  },
  "$defs": {
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client_id", "redirect_uris", "created_at"],
      "properties": {
        "client_id": { "type": "string", "minLength": 1 },
        "client_name": { "type": "string" },
        "redirect_uris": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
