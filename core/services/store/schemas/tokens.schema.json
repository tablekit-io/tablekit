{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tokens.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "codes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/authCode" }
    },
    "chains": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/chain" }
    }
  },
  "$defs": {
    "authCode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "client_id",
        "redirect_uri",
        "code_challenge",
        "scope",
        "user_id",
        "expires_at"
      ],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "client_id": { "type": "string", "minLength": 1 },
        "redirect_uri": { "type": "string", "minLength": 1 },
        "code_challenge": { "type": "string", "minLength": 1 },
        "scope": { "type": "string" },
        "user_id": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "client_id",
        "user_id",
        "scope",
        "redirect_uri",
        "revoked",
        "invalidated_before",
        "created_at"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "client_id": { "type": "string", "minLength": 1 },
        "user_id": { "type": "string", "minLength": 1 },
        "scope": { "type": "string" },
        "redirect_uri": { "type": "string" },
        "revoked": { "type": "boolean" },
        "invalidated_before": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
